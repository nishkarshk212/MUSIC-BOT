# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Bot Configuration (Get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Assistant Account (Your Personal Telegram Account)
# Option 1: Use Session String (RECOMMENDED - Most Reliable)
# Run: python generate_session.py to create a session string
ASSISTANT_SESSION_STRING=your_session_string_here

# Option 2: Use Phone Number (Less reliable, requires login each time)
ASSISTANT_API_ID=your_assistant_api_id_here
ASSISTANT_API_HASH=your_assistant_api_hash_here
ASSISTANT_PHONE=+1234567890  # Your phone number with country code

# Option 3: Use Bot Token (If you created an assistant bot)
# ASSISTANT_BOT_TOKEN=  # Optional: leave empty if using phone/session

# Owner Configuration
OWNER_ID=your_telegram_user_id_here

# Optional Configuration
SUDO_USERS=123456789 987654321  # Space-separated user IDs
DATABASE_URL=mongodb://localhost:27017/music_bot  # Optional MongoDB URL
LOG_GROUP_ID=-1001234567890  # Optional: group ID for logs
MAX_DURATION_MINUTES=60  # Maximum song duration in minutes
